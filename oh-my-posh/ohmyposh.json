{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "session",
          "style": "plain",
          "foreground": "blue",
          "template": "[{{ .UserName }}@{{ .HostName }}]"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "green",
          "properties": {
            "style": "full"
          },
          "template": " {{ .Path }}"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "cyan",
          "properties": {
            "fetch_status": true,
            "fetch_stash_count": true,
            "branch_icon": ""
          },
          "template": " [{{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} {{ .StashCount }}{{ end }}]"
        },
        {
          "type": "python",
          "style": "plain",
          "template": " {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}"
        },
        {
          "type": "aws",
          "style": "plain",
          "foreground": "lightYellow",
          "template": " \uf375{{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} "
        },
        {
          "type": "az",
          "style": "plain",
          "template": " \uebd8 {{ .Name }} "
        },
        {
          "type": "kubectl",
          "style": "plain",
          "template": " \ufd31 {{ .Context }}{{ if .Namespace }} :: {{ .Namespace }}{{ end }} "
        },
        {
          "type": "exit",
          "style": "plain",
          "template": " \ue20f "
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "{{ if or (eq .Shell \"pwsh\") (eq .Shell \"powershell\") }}\u276f {{ else }}$ {{ end }}"
        }
      ]
    }
  ]
}
